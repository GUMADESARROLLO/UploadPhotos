---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout title="Mi Álbum">
  <Navbar />

  <main class="max-w-6xl mx-auto mt-8 px-4 pb-16">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <div>
        <h1 class="text-3xl font-bold font-serif">Álbum</h1>
        <p id="photoCount" class="text-gray-500 mt-1"></p>
      </div>

      <div id="toolbar" class="hidden grid grid-cols-6 sm:flex sm:items-center gap-2 w-full sm:w-auto">
        <button id="selectAllBtn" class="col-span-2 text-sm px-2 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
          Seleccionar todo
        </button>
        <button id="deleteSelectedBtn" class="col-span-2 text-sm px-2 py-2.5 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors cursor-pointer disabled:opacity-30 disabled:cursor-not-allowed">
          Eliminar
        </button>
        <button id="deleteAlbumBtn" class="col-span-2 text-sm px-2 py-2.5 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors cursor-pointer">
          Eliminar todo
        </button>
      </div>
    </div>

    <div id="photoGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      <div class="col-span-full text-center py-20 text-gray-400">
        <span class="text-4xl">🔄</span>
        <p class="mt-3 font-serif">Cargando archivos...</p>
      </div>
    </div>
  </main>

  <div id="viewer" class="hidden fixed inset-0 z-50 bg-black/80 flex items-center justify-center p-4">
    <button id="closeViewer" class="absolute top-4 right-4 text-white text-4xl hover:opacity-70 cursor-pointer z-10">&times;</button>
      <div class="max-w-xl w-full max-h-[90vh]">
        <div id="detailPanel" class="bg-white rounded-xl p-6 space-y-4 max-h-[90vh] overflow-y-auto">
          <div id="detailPreview" class="w-full aspect-video rounded-lg overflow-hidden bg-gray-100 mb-2 flex items-center justify-center">
            <img id="detailImg" class="w-full h-full object-cover hidden" />
            <video id="detailVideo" class="w-full h-full object-contain hidden" controls playsinline></video>
          </div>
          <h3 class="font-semibold text-lg text-wedding-dark font-serif">Detalles</h3>
        <div class="space-y-3 text-sm">
          <div>
            <span class="text-gray-400 block text-xs uppercase tracking-wide">Archivo</span>
            <span id="detailFileName" class="font-medium break-all"></span>
          </div>
          <div>
            <span class="text-gray-400 block text-xs uppercase tracking-wide">Tamaño</span>
            <span id="detailFileSize" class="font-medium"></span>
          </div>
          <div>
            <span class="text-gray-400 block text-xs uppercase tracking-wide">Dimensiones / Duración</span>
            <span id="detailDimensions" class="font-medium"></span>
          </div>
          <div>
            <span class="text-gray-400 block text-xs uppercase tracking-wide">Subida</span>
            <span id="detailDate" class="font-medium"></span>
          </div>
          <div>
            <span class="text-gray-400 block text-xs uppercase tracking-wide">Subido por</span>
            <span id="detailUser" class="font-medium"></span>
          </div>
        </div>
        <div class="flex gap-2">
          <a id="downloadBtn" download class="flex-1 text-center px-3 py-2.5 bg-wedding-gold text-wedding-dark font-medium rounded-lg hover:bg-wedding-gold/90 transition-colors cursor-pointer text-sm">
            Descargar
          </a>
          <button id="deleteSingleBtn" class="flex-1 text-center px-3 py-2.5 bg-red-500 text-white font-medium rounded-lg hover:bg-red-600 transition-colors cursor-pointer text-sm">
            Eliminar
          </button>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { fetchPhotosByGuest, deletePhotoFromServer } from "/js/db.js";

    const guestId = localStorage.getItem("wedding_id");
    const userName = localStorage.getItem("wedding_user");

    if (!userName) {
      window.location.href = "/";
    }

    const count = document.getElementById("photoCount");
    const grid = document.getElementById("photoGrid");
    const toolbar = document.getElementById("toolbar");
    const selectAllBtn = document.getElementById("selectAllBtn");
    const deleteSelectedBtn = document.getElementById("deleteSelectedBtn");
    const deleteAlbumBtn = document.getElementById("deleteAlbumBtn");
    const viewer = document.getElementById("viewer");
    const detailPreview = document.getElementById("detailPreview");
    const detailImg = document.getElementById("detailImg");
    const detailVideo = document.getElementById("detailVideo");
    const detailFileName = document.getElementById("detailFileName");
    const detailFileSize = document.getElementById("detailFileSize");
    const detailDimensions = document.getElementById("detailDimensions");
    const detailDate = document.getElementById("detailDate");
    const detailUser = document.getElementById("detailUser");
    const downloadBtn = document.getElementById("downloadBtn");
    const deleteSingleBtn = document.getElementById("deleteSingleBtn");
    const closeViewer = document.getElementById("closeViewer");

    let photos = [];
    let selected = new Set();
    let currentPhoto = null;

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + " B";
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + " KB";
      return (bytes / 1048576).toFixed(2) + " MB";
    }

    function formatDate(iso) {
      return new Date(iso).toLocaleDateString("es-ES", {
        year: "numeric", month: "long", day: "numeric",
        hour: "2-digit", minute: "2-digit",
      });
    }

    function formatDuration(seconds) {
      const m = Math.floor(seconds / 60);
      const s = Math.floor(seconds % 60);
      return m + ":" + (s < 10 ? "0" : "") + s + " min";
    }

    function getFileMeta(url, isVideo) {
      return new Promise((resolve) => {
        if (isVideo) {
          const v = document.createElement("video");
          v.preload = "metadata";
          v.src = url;
          v.onloadedmetadata = () => {
            const dims = v.videoWidth + " × " + v.videoHeight + " px • " + formatDuration(v.duration);
            resolve(dims);
            v.src = "";
          };
          v.onerror = () => resolve("Desconocido");
        } else {
          const img = new Image();
          img.onload = () => {
            resolve(img.naturalWidth + " × " + img.naturalHeight + " px");
            img.src = "";
          };
          img.onerror = () => resolve("Desconocido");
          img.src = url;
        }
      });
    }

    function updateToolbar() {
      deleteSelectedBtn.disabled = selected.size === 0;
      deleteSelectedBtn.textContent = "Eliminar (" + selected.size + ")";
      const allSelected = photos.length > 0 && selected.size === photos.length;
      selectAllBtn.textContent = allSelected ? "Deseleccionar todo" : "Seleccionar todo";
    }

    function selectPhoto(id) {
      if (selected.has(id)) selected.delete(id);
      else selected.add(id);
      const el = grid.querySelector("[data-id='" + id + "']");
      if (el) el.classList.toggle("ring-2", selected.has(id));
      if (el) el.classList.toggle("ring-wedding-gold", selected.has(id));
      updateToolbar();
    }

    function showDetails(photo) {
      currentPhoto = photo;
      viewer.classList.remove("hidden");

      detailImg.classList.add("hidden");
      detailVideo.classList.add("hidden");
      detailVideo.pause();
      detailVideo.removeAttribute("src");

      if (photo.isVideo) {
        detailVideo.src = photo.url;
        detailVideo.load();
        detailVideo.classList.remove("hidden");
      } else {
        detailImg.src = photo.url;
        detailImg.classList.remove("hidden");
      }

      detailFileName.textContent = photo.fileName;
      detailFileSize.textContent = formatSize(photo.size);
      detailDate.textContent = formatDate(photo.uploadedAt);
      detailUser.textContent = photo.userName;
      detailDimensions.textContent = "Calculando...";

      const url = photo.isVideo ? photo.url : photo.url;
      getFileMeta(url, photo.isVideo).then((meta) => {
        detailDimensions.textContent = meta;
      });
    }

    function renderPhotos() {
      if (photos.length === 0) {
        grid.innerHTML = [
          '<div class="col-span-full text-center py-20 text-gray-400">',
          '  <span class="text-4xl">📸</span>',
          '  <p class="mt-3 text-lg font-medium font-serif">Aún no has subido archivos</p>',
          '  <a href="/upload" class="inline-block mt-4 px-6 py-2.5 bg-wedding-gold text-wedding-dark font-medium rounded-xl hover:bg-wedding-gold/90 transition-colors">Subir Fotos y Videos</a>',
          '</div>',
        ].join("\n");
        toolbar.classList.add("hidden");
        return;
      }

      toolbar.classList.remove("hidden");
      count.textContent = photos.length + " archivo" + (photos.length !== 1 ? "s" : "");
      grid.innerHTML = "";

      for (const photo of photos) {
        const item = document.createElement("div");
        item.className =
          "aspect-square overflow-hidden rounded-xl bg-gray-100 cursor-pointer group relative";
        item.dataset.id = photo.id;
        if (selected.has(photo.id)) {
          item.classList.add("ring-2", "ring-wedding-gold");
        }

        const cb = document.createElement("input");
        cb.type = "checkbox";
        cb.checked = selected.has(photo.id);
        cb.className =
          "absolute top-2 left-2 z-10 w-5 h-5 accent-wedding-gold cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity";
        cb.addEventListener("click", (e) => {
          e.stopPropagation();
          selectPhoto(photo.id);
        });

        if (photo.isVideo) {
          const video = document.createElement("video");
          video.className = "w-full h-full object-cover";
          video.src = photo.url;
          video.preload = "metadata";
          video.muted = true;
          video.playsinline = true;

          const playOverlay = document.createElement("div");
          playOverlay.className =
            "absolute inset-0 flex items-center justify-center bg-black/10 group-hover:bg-black/20 transition-colors";
          playOverlay.innerHTML =
            '<span class="text-4xl opacity-80 drop-shadow-lg">▶</span>';

          item.appendChild(cb);
          item.appendChild(video);
          item.appendChild(playOverlay);
        } else {
          const img = document.createElement("img");
          img.className =
            "w-full h-full object-cover transition-transform group-hover:scale-105 duration-300";
          img.src = photo.url;
          img.loading = "lazy";

          const overlay = document.createElement("div");
          overlay.className =
            "absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-end p-3";

          const info = document.createElement("div");
          info.className = "text-white text-xs opacity-0 group-hover:opacity-100 transition-opacity";
          info.textContent = formatDate(photo.uploadedAt);

          overlay.appendChild(info);
          item.appendChild(cb);
          item.appendChild(img);
          item.appendChild(overlay);
        }

        item.addEventListener("click", (e) => {
          if (e.target.closest("[data-id]") === item) {
            showDetails(photo);
          }
        });

        grid.appendChild(item);
      }
      updateToolbar();
    }

    async function loadPhotos() {
      if (!guestId) {
        photos = [];
        renderPhotos();
        return;
      }

      const serverPhotos = await fetchPhotosByGuest(guestId);
      photos = serverPhotos.map((sp) => ({
        id: sp.id,
        fileName: sp.fileName,
        size: sp.size,
        type: sp.type,
        userName: sp.userName,
        uploadedAt: sp.uploadedAt,
        url: sp.url,
        isVideo: sp.type && sp.type.startsWith("video/"),
      }));

      selected.clear();
      renderPhotos();
    }

    selectAllBtn.addEventListener("click", () => {
      const allSelected = photos.length > 0 && selected.size === photos.length;
      if (allSelected) {
        selected.clear();
      } else {
        photos.forEach((p) => selected.add(p.id));
      }
      photos.forEach((p) => {
        const el = grid.querySelector("[data-id='" + p.id + "']");
        if (el) {
          el.classList.toggle("ring-2", selected.has(p.id));
          el.classList.toggle("ring-wedding-gold", selected.has(p.id));
          const cb = el.querySelector("input[type=checkbox]");
          if (cb) cb.checked = selected.has(p.id);
        }
      });
      updateToolbar();
    });

    deleteSelectedBtn.addEventListener("click", async () => {
      const n = selected.size;
      if (!confirm("Eliminar " + n + " archivo" + (n !== 1 ? "s" : "") + " seleccionado" + (n !== 1 ? "s" : "") + "?")) return;
      for (const id of [...selected]) {
        const photo = photos.find((p) => p.id === id);
        if (photo?.url) await deletePhotoFromServer(photo.url);
      }
      await loadPhotos();
    });

    deleteAlbumBtn.addEventListener("click", async () => {
      if (!confirm("Eliminar todo tu álbum (" + photos.length + " archivos)? Esta acción no se puede deshacer.")) return;
      for (const photo of photos) {
        if (photo.url) await deletePhotoFromServer(photo.url);
      }
      viewer.classList.add("hidden");
      await loadPhotos();
    });

    deleteSingleBtn.addEventListener("click", async () => {
      if (!currentPhoto) return;
      if (!confirm('Eliminar "' + currentPhoto.fileName + '"?')) return;
      if (currentPhoto.url) await deletePhotoFromServer(currentPhoto.url);
      viewer.classList.add("hidden");
      await loadPhotos();
    });

    closeViewer.addEventListener("click", () => {
      detailVideo.pause();
      viewer.classList.add("hidden");
    });
    viewer.addEventListener("click", (e) => {
      if (e.target === viewer) {
        detailVideo.pause();
        viewer.classList.add("hidden");
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        detailVideo.pause();
        viewer.classList.add("hidden");
      }
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", loadPhotos);
    } else {
      loadPhotos();
    }
  </script>
</Layout>
